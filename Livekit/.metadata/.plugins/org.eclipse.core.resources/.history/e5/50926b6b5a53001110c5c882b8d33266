package com.knowlia.lms_live_service.dto;

import jakarta.validation.constraints.NotBlank;
import jakarta.validation.constraints.Pattern;
import jakarta.validation.constraints.Size;

/**
 * Request DTO for joining a live session.
 * All fields are validated before processing.
 */
public class JoinRequest {

    @NotBlank(message = "roomName is required")
    @Size(min = 1, max = 100, message = "roomName must be between 1 and 100 characters")
    @Pattern(regexp = "^[a-zA-Z0-9-]+$", message = "roomName must contain only alphanumeric characters and dashes")
    private String roomName;

    @NotBlank(message = "studentId is required")
    @Size(min = 1, max = 100, message = "studentId must be between 1 and 100 characters")
    @Pattern(regexp = "^[a-zA-Z0-9-]+$", message = "studentId must contain only alphanumeric characters and dashes")
    private String studentId;

    @NotBlank(message = "studentName is required")
    @Size(min = 1, max = 100, message = "studentName must be between 1 and 100 characters")
    private String studentName;

    public JoinRequest() {
    }

    public JoinRequest(String roomName, String studentId, String studentName) {
        this.roomName = roomName;
        this.studentId = studentId;
        this.studentName = studentName;
    }

    public String getRoomName() {
        return roomName;
    }

    public void setRoomName(String roomName) {
        this.roomName = roomName;
    }

    public String getStudentId() {
        return studentId;
    }

    public void setStudentId(String studentId) {
        this.studentId = studentId;
    }

    public String getStudentName() {
        return studentName;
    }

    public void setStudentName(String studentName) {
        this.studentName = studentName;
    }
}
